---
---

<section class="features-grid-section">
  <div class="inner">
    <div class="section-header">
      <span class="section-label">What I build with</span>
      <h2 class="section-heading">Build with what actually works.</h2>
      <p class="section-sub">Tools chosen for longevity, not hype.</p>
    </div>

    <div class="grid">
      <!-- Col 1: Frontend -->
      <div class="col-card">
        <div class="col-header">
          <div class="col-icon-plate">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="3" width="16" height="11" rx="1"/>
              <path d="M7 17h6M10 14v3"/>
            </svg>
          </div>
          <h3 class="col-title">Frontend</h3>
          <p class="col-desc">Client-side done right.</p>
        </div>
        <div class="divider"></div>
        <ul class="sub-items">
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 7l-2 3 2 3M15 7l2 3-2 3M12 4l-4 12"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">Astro</span>
              <span class="sub-desc">Zero JS by default. Content-first architecture that ships fast.</span>
            </div>
          </li>
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="10" cy="10" r="2.5"/>
                <ellipse cx="10" cy="10" rx="8" ry="3.5"/>
                <ellipse cx="10" cy="10" rx="8" ry="3.5" transform="rotate(60 10 10)"/>
                <ellipse cx="10" cy="10" rx="8" ry="3.5" transform="rotate(120 10 10)"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">React</span>
              <span class="sub-desc">When interactivity actually justifies the runtime cost.</span>
            </div>
          </li>
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 6h5v5H4zM11 6h5v5h-5zM4 13h5v5H4zM11 13h5v5h-5z" stroke-width="1.2"/>
                <text x="6" y="12" font-size="8" font-weight="700" fill="currentColor" stroke="none" font-family="sans-serif">T</text>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">TypeScript</span>
              <span class="sub-desc">Types are documentation that never goes stale.</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Col 2: Backend & Data -->
      <div class="col-card">
        <div class="col-header">
          <div class="col-icon-plate">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <ellipse cx="10" cy="5" rx="7" ry="2.5"/>
              <path d="M3 5v4c0 1.38 3.13 2.5 7 2.5S17 10.38 17 9V5"/>
              <path d="M3 9v4c0 1.38 3.13 2.5 7 2.5S17 14.38 17 13V9"/>
            </svg>
          </div>
          <h3 class="col-title">Backend &amp; Data</h3>
          <p class="col-desc">Server-side without surprises.</p>
        </div>
        <div class="divider"></div>
        <ul class="sub-items">
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 2l1.5 4.5H16l-3.5 2.5 1.5 4.5L10 11l-4 2.5 1.5-4.5L4 6.5h4.5L10 2z"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">Node.js</span>
              <span class="sub-desc">Same language end to end. No context switching.</span>
            </div>
          </li>
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <ellipse cx="10" cy="7" rx="7" ry="2.5"/>
                <path d="M3 7v6c0 1.38 3.13 2.5 7 2.5S17 14.38 17 13V7"/>
                <path d="M3 10c0 1.38 3.13 2.5 7 2.5S17 11.38 17 10"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">PostgreSQL</span>
              <span class="sub-desc">Relational, reliable, boring in the best way.</span>
            </div>
          </li>
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 10h12M13 7l3 3-3 3M7 7L4 10l3 3"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">REST APIs</span>
              <span class="sub-desc">Typed contracts, zero codegen overhead.</span>
            </div>
          </li>
        </ul>
      </div>

      <!-- Col 3: Developer Experience -->
      <div class="col-card">
        <div class="col-header">
          <div class="col-icon-plate">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M10 2l1.2 3.6H17l-2.9 2.1 1.2 3.6L12.5 9l-2.5 1.8-1.8-3.6L4 9.7l1.2-3.6L2.5 4H9L10 2z"/>
              <path d="M10 12v6M7 15l3 3 3-3"/>
            </svg>
          </div>
          <h3 class="col-title">Developer Experience</h3>
          <p class="col-desc">Tooling that gets out of the way.</p>
        </div>
        <div class="divider"></div>
        <ul class="sub-items">
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 10l4 4 8-8"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">Vitest</span>
              <span class="sub-desc">Fast unit tests without ceremony or config hell.</span>
            </div>
          </li>
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M10 3v4M10 3l-3 2M10 3l3 2M4 14l3-5M4 14H2M4 14l1 3M16 14l-3-5M16 14h2M16 14l-1 3M10 7l-3 7M10 7l3 7"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">Git + GitHub</span>
              <span class="sub-desc">Version everything. Open source when possible.</span>
            </div>
          </li>
          <li class="sub-item">
            <div class="sub-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="4" width="16" height="12" rx="1.5"/>
                <path d="M6 8l3 3-3 3M11 14h3"/>
              </svg>
            </div>
            <div class="sub-text">
              <span class="sub-title">VS Code</span>
              <span class="sub-desc">Configured once, used everywhere, extended never unnecessarily.</span>
            </div>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .features-grid-section {
    background: var(--color-canvas-soft);
    border-top: 1px solid var(--color-hairline);
    border-bottom: 1px solid var(--color-hairline);
  }

  .inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-section, 96px) var(--space-xl, 32px);
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-xxl, 48px);
  }

  .section-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.88px;
    color: var(--color-muted);
    margin-bottom: var(--space-sm, 12px);
  }

  .section-heading {
    font-size: 36px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -1.08px;
    line-height: 1.15;
    margin: 0 0 var(--space-sm, 12px);
  }

  .section-sub {
    font-size: 16px;
    color: var(--color-body);
    line-height: 1.5;
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl, 32px);
  }

  .col-card {
    background: var(--color-surface-card);
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-lg, 12px);
    padding: 28px;
  }

  .col-header {
    margin-bottom: var(--space-lg, 24px);
  }

  .col-icon-plate {
    width: 32px;
    height: 32px;
    background: var(--color-surface-strong);
    border-radius: var(--radius-md, 8px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-ink);
  }

  .col-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-ink);
    margin: var(--space-base, 16px) 0 0;
    line-height: 1.4;
  }

  .col-desc {
    font-size: 14px;
    color: var(--color-body);
    margin: var(--space-xs, 8px) 0 0;
    line-height: 1.5;
  }

  .divider {
    height: 1px;
    background: var(--color-hairline);
    margin-bottom: 0;
  }

  .sub-items {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sub-item {
    display: flex;
    gap: var(--space-sm, 12px);
    padding-top: var(--space-base, 16px);
  }

  .sub-icon {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: var(--color-muted);
    display: flex;
    align-items: flex-start;
    padding-top: 1px;
  }

  .sub-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sub-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.4;
  }

  .sub-desc {
    font-size: 13px;
    color: var(--color-body);
    line-height: 1.5;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .section-heading {
      font-size: 28px;
    }
  }
</style>
