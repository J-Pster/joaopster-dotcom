---
interface WakatimeLanguage {
  name: string;
  percent: number;
  text: string;
}

interface WakatimeData {
  totalText: string;
  dailyAvgText: string;
  languages: WakatimeLanguage[];
}

interface Props {
  label: string;
  heading: string;
  body: string;
  addendum?: string;
  cta?: { text: string; href: string };
  variant: 'build' | 'write' | 'opensource';
  flip?: boolean;
  wakatimeData?: WakatimeData;
}

const { label, heading, body, addendum, cta, variant, flip = false, wakatimeData } = Astro.props;
---

<section id={variant === 'opensource' ? 'opensource' : undefined} class:list={['workflow-section', flip && 'workflow-section--flip']}>
  <div class="workflow-inner">
    <div class="workflow-text">
      <span class="workflow-label">{label}</span>
      <h2 class="workflow-heading">{heading}</h2>
      <p class="workflow-body">{body}</p>
      {addendum && <p class="workflow-addendum">{addendum}</p>}
      {cta && (
        <a class="workflow-cta" href={cta.href}>{cta.text} →</a>
      )}
    </div>

    <div class="workflow-card">
      {variant === 'build' && (
        <div class="card-build">
          <div class="build-titlebar">
            <span class="build-title">Production deploy</span>
            <span class="build-dot"></span>
          </div>
          <div class="build-rows">
            <div class="build-row">
              <span class="build-icon">✓</span>
              <span class="build-label">TypeScript check</span>
              <span class="build-badge build-badge--passed">Passed</span>
            </div>
            <div class="build-row">
              <span class="build-icon">✓</span>
              <span class="build-label">Unit tests (47)</span>
              <span class="build-badge build-badge--passed">Passed</span>
            </div>
            <div class="build-row">
              <span class="build-icon">✓</span>
              <span class="build-label">Build complete</span>
              <span class="build-badge build-badge--metric">1.2s</span>
            </div>
            <div class="build-row">
              <span class="build-icon">✓</span>
              <span class="build-label">Deployed</span>
              <span class="build-badge build-badge--metric">Live</span>
            </div>
          </div>
          <div class="build-url">https://joaopster.com</div>
        </div>
      )}

      {variant === 'write' && (
        <div class="card-write">
          <span class="write-pill">Latest post</span>
          <h3 class="write-post-title">Anti-vibe-coding: engineering rigor for AI</h3>
          <span class="write-post-date">May 2026</span>
          <div class="write-divider"></div>
          <div class="write-preview-wrap">
            <p class="write-preview">
              AI coding isn't about one-shot prompts and luck. It's the same discipline that makes any project succeed: clear decisions, explicit architecture, phased execution, and structured review. The developer controls the path; the AI executes the steps.
            </p>
            <div class="write-fade"></div>
          </div>
          <div class="write-footer">
            <a class="write-read-more" href="/blog/anti-vibe-coding/">Read more →</a>
            <span class="write-read-time">4 min read</span>
          </div>
        </div>
      )}

      {variant === 'opensource' && (
        <div class="card-wakatime">
          <div class="waka-header">
            <div class="waka-brand-row">
              <span class="waka-dot"></span>
              <span class="waka-brand">WakaTime</span>
            </div>
            <span class="waka-user">@JoaoPster</span>
          </div>

          <div class="waka-metrics">
            <div class="waka-metric">
              <span class="waka-metric-value">{wakatimeData?.totalText ?? '---'}</span>
              <span class="waka-metric-label">Total coded</span>
            </div>
            <div class="waka-metric-sep"></div>
            <div class="waka-metric">
              <span class="waka-metric-value">{wakatimeData?.dailyAvgText ?? '---'}</span>
              <span class="waka-metric-label">Daily avg</span>
            </div>
          </div>

          <div class="waka-divider"></div>

          <div class="waka-langs">
            {(wakatimeData?.languages ?? []).map((lang) => (
              <div class="waka-lang">
                <div class="waka-lang-row">
                  <span class="waka-lang-name">{lang.name}</span>
                  <span class="waka-lang-pct">{lang.percent.toFixed(1)}%</span>
                </div>
                <div class="waka-bar-track">
                  <div class="waka-bar-fill" style={`width:${Math.min(lang.percent, 100)}%`}></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .workflow-section {
    background: var(--color-canvas);
    border-top: 1px solid var(--color-hairline);
  }

  .workflow-section--flip {
    background: var(--color-canvas-soft);
  }

  .workflow-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: var(--space-section) var(--space-xl);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  /* Text always order 1, card order 2 */
  .workflow-text {
    order: 1;
  }

  .workflow-card {
    order: 2;
  }

  /* flip: text goes to right, card to left */
  .workflow-section--flip .workflow-text {
    order: 2;
  }

  .workflow-section--flip .workflow-card {
    order: 1;
  }

  /* --- Text column --- */
  .workflow-label {
    display: block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.88px;
    color: var(--color-muted);
    margin-bottom: var(--space-base);
  }

  .workflow-heading {
    font-size: 36px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -1.08px;
    line-height: 1.15;
    margin: 0 0 var(--space-base) 0;
  }

  .workflow-body {
    font-size: 16px;
    color: var(--color-body);
    line-height: 1.7;
    margin: 0 0 12px 0;
  }

  .workflow-addendum {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0 0 28px 0;
    padding: 10px 14px;
    border-left: 2px solid var(--color-hairline-strong);
  }

  .workflow-cta {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-link);
    text-decoration: none;
  }

  .workflow-cta:hover {
    text-decoration: underline;
  }

  /* --- Dark card --- */
  .workflow-card {
    background: var(--color-surface-dark);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-xl);
    padding: 28px;
    min-height: 280px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* === BUILD variant === */
  .card-build {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-radius: calc(var(--radius-xl) - 4px);
    overflow: hidden;
  }

  .build-titlebar {
    background: var(--color-surface-dark-elevated);
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-radius: calc(var(--radius-xl) - 4px) calc(var(--radius-xl) - 4px) 0 0;
  }

  .build-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-on-dark);
    font-family: 'JetBrains Mono', monospace;
  }

  .build-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #28c840;
  }

  .build-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 8px 0;
  }

  .build-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px;
  }

  .build-icon {
    font-size: 12px;
    color: #28c840;
    width: 16px;
    flex-shrink: 0;
    font-family: 'JetBrains Mono', monospace;
  }

  .build-label {
    font-size: 13px;
    color: var(--color-on-dark-soft);
    flex: 1;
    font-family: 'JetBrains Mono', monospace;
  }

  .build-badge {
    font-size: 10px;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 9999px;
    white-space: nowrap;
    font-family: 'JetBrains Mono', monospace;
  }

  .build-badge--passed {
    background: rgba(40, 200, 64, 0.15);
    color: #28c840;
  }

  .build-badge--metric {
    background: rgba(71, 194, 255, 0.15);
    color: #47c2ff;
  }

  .build-url {
    padding: 10px 16px 4px;
    font-size: 12px;
    font-family: 'JetBrains Mono', monospace;
    color: #47c2ff;
  }

  /* === WRITE variant === */
  .card-write {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .write-pill {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.88px;
    color: var(--color-on-dark-soft);
    background: rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    padding: 3px 10px;
    margin-bottom: 12px;
    width: fit-content;
  }

  .write-post-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--color-on-dark);
    margin: 0 0 6px 0;
    line-height: 1.4;
  }

  .write-post-date {
    font-size: 12px;
    color: var(--color-on-dark-soft);
    margin-bottom: 14px;
    display: block;
  }

  .write-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
    margin-bottom: 14px;
  }

  .write-preview-wrap {
    position: relative;
    margin-bottom: 16px;
  }

  .write-preview {
    font-size: 13px;
    color: var(--color-on-dark-soft);
    line-height: 1.6;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .write-fade {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 28px;
    background: linear-gradient(to bottom, transparent, var(--color-surface-dark));
    pointer-events: none;
  }

  .write-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .write-read-more {
    font-size: 13px;
    font-weight: 500;
    color: #47c2ff;
    text-decoration: none;
  }

  .write-read-more:hover {
    text-decoration: underline;
  }

  .write-read-time {
    font-size: 12px;
    color: var(--color-on-dark-soft);
  }

  /* === WAKATIME card (opensource variant) === */
  .card-wakatime {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .waka-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .waka-brand-row {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .waka-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #28c840;
    flex-shrink: 0;
  }

  .waka-brand {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-on-dark);
    font-family: 'JetBrains Mono', monospace;
  }

  .waka-user {
    font-size: 12px;
    color: var(--color-on-dark-soft);
    font-family: 'JetBrains Mono', monospace;
  }

  .waka-metrics {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .waka-metric {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .waka-metric-value {
    font-size: 17px;
    font-weight: 600;
    color: var(--color-on-dark);
    font-family: 'JetBrains Mono', monospace;
    letter-spacing: -0.5px;
  }

  .waka-metric-label {
    font-size: 10px;
    color: var(--color-on-dark-soft);
    text-transform: uppercase;
    letter-spacing: 0.6px;
  }

  .waka-metric-sep {
    width: 1px;
    height: 36px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0 20px;
    flex-shrink: 0;
  }

  .waka-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.08);
  }

  .waka-langs {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .waka-lang {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .waka-lang-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .waka-lang-name {
    font-size: 12px;
    color: var(--color-on-dark-soft);
    font-family: 'JetBrains Mono', monospace;
  }

  .waka-lang-pct {
    font-size: 11px;
    color: #47c2ff;
    font-family: 'JetBrains Mono', monospace;
  }

  .waka-bar-track {
    height: 4px;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    overflow: hidden;
  }

  .waka-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, #47c2ff, #3b9fe0);
    border-radius: 9999px;
  }

  /* === Responsive === */
  @media (max-width: 900px) {
    .workflow-inner {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 64px var(--space-base);
    }

    /* Text always first on mobile regardless of flip */
    .workflow-text {
      order: 1 !important;
    }

    .workflow-card {
      order: 2 !important;
      min-height: auto;
    }
  }
</style>
