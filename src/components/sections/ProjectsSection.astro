---
import { useTranslations, defaultLang, type Lang } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const projects = [
  { title: 'Psters AI Workflow', desc: t('projects.p5.desc'), dark: true, icon: 'M9 1.5l2 4 4.5.5-3.3 3 .9 4.5L9 11.3 4.9 13.5l.9-4.5L2.5 6l4.5-.5 2-4z', url: 'https://github.com/J-Pster/Psters_AI_Workflow' },
  { title: 'oh-my-claudecode', desc: t('projects.p7.desc'), dark: true, icon: 'M9 2a2 2 0 100 4 2 2 0 000-4zM3 13a2 2 0 100 4 2 2 0 000-4zM15 13a2 2 0 100 4 2 2 0 000-4zM9 6v4.5M9 10.5L4.5 13M9 10.5l4.5 2.5', url: 'https://github.com/Yeachan-Heo/oh-my-claudecode' },
  { title: 'rtk', desc: t('projects.p8.desc'), dark: true, icon: 'M2 3h14v12H2V3zM2 7.5h14M5 11l2 2-2 2M10 15h3', url: 'https://github.com/rtk-ai/rtk' },
];
---
<section class="projects-section" id="projects">
  <div class="projects-inner">
    <p class="proj-label">{t('projects.label')}</p>
    <h2 class="proj-heading">{t('projects.heading')}</h2>
    <p class="proj-sub">{t('projects.sub')}</p>
    <div class="proj-grid">
      {projects.map(p => (
        <a href={p.url} target="_blank" rel="noopener noreferrer" class={`proj-card ${p.dark ? 'proj-card--dark' : 'proj-card--light'}`}>
          <div class={`proj-icon ${p.dark ? '' : 'proj-icon--light'}`}>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d={p.icon} stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3>{p.title}</h3>
          <p>{p.desc}</p>
          <span class={p.dark ? 'proj-link' : 'proj-link-light'}>{t('projects.github')}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-section { padding: var(--space-section) var(--space-xl); background: var(--color-canvas-soft); border-top: 1px solid var(--color-hairline); border-bottom: 1px solid var(--color-hairline); }
  .projects-inner { max-width: 1000px; margin: 0 auto; }
  .proj-label { font-size: 11px; font-weight: 600; letter-spacing: 0.88px; text-transform: uppercase; color: var(--color-muted); margin-bottom: var(--space-md); }
  .proj-heading { font-size: 36px; font-weight: 600; color: var(--color-ink); letter-spacing: -1.08px; line-height: 1.15; margin-bottom: var(--space-sm); }
  .proj-sub { font-size: 15px; color: var(--color-body); margin-bottom: var(--space-xxl); }
  .proj-grid { display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: auto; gap: var(--space-base); }
  .proj-card { border-radius: var(--radius-lg); padding: var(--space-lg); text-decoration: none; display: flex; flex-direction: column; height: 100%; box-sizing: border-box; transition: transform 200ms ease-out, box-shadow 200ms ease-out; }
  .proj-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.06); text-decoration: none; }
  .proj-card--dark { background: var(--color-surface-dark); border: 1px solid rgba(255,255,255,0.06); }
  .proj-card--dark h3 { color: var(--color-on-dark); font-size: 18px; font-weight: 600; margin: var(--space-md) 0 var(--space-sm); font-family: 'JetBrains Mono', monospace; letter-spacing: -0.3px; }
  .proj-card--dark p { color: var(--color-on-dark-soft); font-size: 14px; line-height: 1.6; flex: 1; margin-bottom: var(--space-md); }
  .proj-card--light { background: var(--color-surface-card); border: 1px solid var(--color-hairline-strong); }
  .proj-card--light h3 { color: var(--color-ink); font-size: 18px; font-weight: 600; margin: var(--space-md) 0 var(--space-sm); font-family: 'JetBrains Mono', monospace; letter-spacing: -0.3px; }
  .proj-card--light p { color: var(--color-body); font-size: 14px; line-height: 1.6; flex: 1; margin-bottom: var(--space-md); }
  .proj-icon { width: 32px; height: 32px; background: rgba(255,255,255,0.08); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; color: var(--color-on-dark-soft); }
  .proj-icon--light { background: var(--color-surface-strong); color: var(--color-ink); }
  .proj-link { font-size: 13px; font-weight: 500; color: #47c2ff; }
  .proj-link-light { font-size: 13px; font-weight: 500; color: var(--color-text-link); }
.proj-footer { margin-top: var(--space-xxl); text-align: center; }
  .proj-all-btn { display: inline-flex; align-items: center; border: 1px solid var(--color-hairline-strong); background: var(--color-canvas); color: var(--color-ink); font-size: 14px; font-weight: 500; padding: 10px 20px; height: 40px; border-radius: var(--radius-md); text-decoration: none; transition: border-color 0.15s; }
  .proj-all-btn:hover { border-color: var(--color-muted); text-decoration: none; }
  @media (max-width: 900px) { .proj-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) {
    .projects-section { padding: var(--space-section) var(--space-base); }
    .proj-grid { grid-template-columns: 1fr; grid-auto-rows: auto; }
    .proj-heading { font-size: 28px; }
  }
</style>
