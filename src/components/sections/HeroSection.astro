---
import { useTranslations, defaultLang, type Lang } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const prefix = lang === 'pt' ? '' : `/${lang}`;
---
<section class="hero">
  <div class="hero-blob hero-blob-1" aria-hidden="true"></div>
  <div class="hero-blob hero-blob-2" aria-hidden="true"></div>
  <div class="hero-blob hero-blob-3" aria-hidden="true"></div>
  <div class="hero-blob hero-blob-4" aria-hidden="true"></div>
  <div class="hero-inner">
    <p class="hero-badge">{t('hero.badge')}</p>
    <h1>{t('hero.h1Line1')}<br/>{t('hero.h1Line2')}</h1>
    <p class="hero-sub">{t('hero.sub')}</p>
    <div class="hero-stats">
      <div class="stat">
        <span class="stat-n">6+</span>
        <span class="stat-l">{t('hero.yearsBuilding')}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-n">30</span>
        <span class="stat-l">{t('hero.openSourceRepos')}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-n">290+</span>
        <span class="stat-l">{t('hero.githubStars')}</span>
      </div>
    </div>
    <div class="hero-ctas">
      <a href={`${prefix}/blog`} class="btn-primary">{t('hero.readBlog')}</a>
      <a href="https://github.com/J-Pster" target="_blank" rel="noopener noreferrer" class="btn-secondary">{t('hero.viewGithub')}</a>
    </div>
  </div>
  <div class="hero-mockup-wrap">
    <div class="mockup-window">
      <div class="mockup-bar">
        <div class="mockup-dots">
          <span class="dot-r"></span>
          <span class="dot-y"></span>
          <span class="dot-g"></span>
        </div>
        <span class="mockup-title">~/work · zsh</span>
      </div>
      <div class="mockup-body">
        <div class="ml"><span class="mp">❯</span> <span class="mc">spec new</span> <span class="mhi">"add billing webhooks"</span></div>
        <div class="ml mo"><span class="mg">◼</span> Architecture decisions recorded</div>
        <div class="ml mo"><span class="mg">◼</span> Phased plan ready, 6 steps</div>
        <div class="ml mo"><span class="mb">→</span> Engineering rigor, not vibes.</div>
        <div class="ml mt8"><span class="mp">❯</span> <span class="mc">npm run check</span></div>
        <div class="ml mo"><span class="mg">✓</span> 0 type errors · 47 tests passed</div>
        <div class="ml mt8"><span class="mp">❯</span> <span class="mc">git commit -m</span> <span class="mhi">"feat: typed, tested, shipped"</span></div>
        <div class="ml mo"><span class="mb">→</span> deployed to <span class="mb">production</span></div>
        <div class="ml mt8"><span class="mp">❯</span> <span class="mc-cursor">█</span></div>
      </div>
    </div>
  </div>
</section>

<script>
  import { animate, stagger } from "motion";

  // Staggered entrance: badge → h1 → sub → stats → CTAs
  animate(
    ".hero-inner > *",
    {
      opacity: [0, 1],
      transform: ["translateY(20px)", "translateY(0px)"],
    },
    {
      delay: stagger(0.1, { start: 0.05 }),
      duration: 0.55,
      easing: "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
    }
  );

  // Terminal mockup slides up after content
  animate(
    ".hero-mockup-wrap",
    {
      opacity: [0, 1],
      transform: ["translateY(32px)", "translateY(0px)"],
    },
    {
      delay: 0.45,
      duration: 0.65,
      easing: "cubic-bezier(0.25, 0.46, 0.45, 0.94)",
    }
  );

  // Terminal lines appear one-by-one (typewriter feel)
  animate(
    ".mockup-body .ml",
    { opacity: [0, 1] },
    {
      delay: stagger(0.09, { start: 0.8 }),
      duration: 0.22,
      easing: "ease-out",
    }
  );

  // Atmospheric blobs float via transform-only WAAPI (GPU compositor thread)
  animate(
    ".hero-blob-1",
    { transform: ["translate(0, 0)", "translate(70px, -50px)", "translate(-35px, 28px)", "translate(0, 0)"] },
    { duration: 14, repeat: Infinity, easing: "ease-in-out" }
  );
  animate(
    ".hero-blob-2",
    { transform: ["translate(0, 0)", "translate(-60px, 38px)", "translate(30px, -65px)", "translate(0, 0)"] },
    { duration: 18, repeat: Infinity, easing: "ease-in-out" }
  );
  animate(
    ".hero-blob-3",
    { transform: ["translate(0, 0)", "translate(45px, -35px)", "translate(-55px, 50px)", "translate(0, 0)"] },
    { duration: 22, repeat: Infinity, easing: "ease-in-out" }
  );
  animate(
    ".hero-blob-4",
    { transform: ["translate(0, 0)", "translate(40px, -20px)", "translate(-40px, -10px)", "translate(0, 0)"] },
    { duration: 26, repeat: Infinity, easing: "ease-in-out" }
  );
</script>

<style>
  @property --sky-h {
    syntax: '<percentage>';
    initial-value: 70%;
    inherits: false;
  }
  @property --sky-top {
    syntax: '<percentage>';
    initial-value: -15%;
    inherits: false;
  }
  @keyframes sky-breathe {
    from { --sky-h: 70%; --sky-top: -15%; }
    to   { --sky-h: 95%; --sky-top: -4%; }
  }
  @keyframes blob-pulse-1 {
    0%, 100% { opacity: 0.50; }
    50%      { opacity: 0.25; }
  }
  @keyframes blob-pulse-2 {
    0%, 100% { opacity: 0.42; }
    50%      { opacity: 0.20; }
  }
  @keyframes blob-pulse-3 {
    0%, 100% { opacity: 0.38; }
    50%      { opacity: 0.18; }
  }
  @keyframes blob-pulse-4 {
    0%, 100% { opacity: 0.22; }
    50%      { opacity: 0.10; }
  }
  .hero-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(64px);
    will-change: transform, opacity;
    z-index: 0;
  }
  .hero-blob-1 {
    width: 520px; height: 520px;
    background: radial-gradient(circle, #cfe7ff 0%, transparent 70%);
    top: -100px; left: -120px;
    animation: blob-pulse-1 7s ease-in-out infinite;
  }
  .hero-blob-2 {
    width: 440px; height: 440px;
    background: radial-gradient(circle, #a8c8e8 0%, transparent 70%);
    top: -30px; right: -100px;
    animation: blob-pulse-2 9s ease-in-out infinite;
    animation-delay: -3s;
  }
  .hero-blob-3 {
    width: 380px; height: 380px;
    background: radial-gradient(circle, #cfe7ff 0%, transparent 70%);
    top: 60px; left: 36%;
    animation: blob-pulse-3 11s ease-in-out infinite;
    animation-delay: -5s;
  }
  .hero-blob-4 {
    width: 600px; height: 600px;
    background: radial-gradient(circle, #daeeff 0%, transparent 70%);
    bottom: -120px; left: calc(50% - 300px);
    animation: blob-pulse-4 13s ease-in-out infinite;
    animation-delay: -7s;
  }
  .hero {
    background:
      radial-gradient(ellipse 110% var(--sky-h) at 50% var(--sky-top), #cfe7ff 0%, #daeeff 20%, transparent 58%),
      #ffffff;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    position: relative;
    animation: sky-breathe 9s ease-in-out infinite alternate;
  }
  .hero-inner {
    max-width: 760px;
    width: 100%;
    margin: 0 auto;
    padding: 96px var(--space-xl) 64px;
    text-align: center;
    position: relative;
    z-index: 1;
  }
  .hero-badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.88px;
    text-transform: uppercase;
    color: var(--color-muted);
    background: var(--color-surface-strong);
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-lg);
  }
  .hero h1 {
    font-size: 64px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -1.92px;
    line-height: 1.05;
    margin-bottom: var(--space-lg);
  }
  .hero-sub {
    font-size: 18px;
    color: var(--color-body);
    line-height: 1.65;
    max-width: 500px;
    margin: 0 auto var(--space-xxl);
  }
  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-xl);
    margin-bottom: var(--space-xxl);
  }
  .stat { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  .stat-n { font-size: 28px; font-weight: 600; color: var(--color-ink); letter-spacing: -0.84px; line-height: 1; }
  .stat-l { font-size: 13px; color: var(--color-muted); line-height: 1.4; }
  .stat-divider { width: 1px; height: 36px; background: var(--color-hairline-strong); flex-shrink: 0; }
  .hero-ctas { display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap; }
  .btn-primary {
    display: inline-flex; align-items: center;
    background: var(--color-primary); color: var(--color-on-primary);
    font-size: 14px; font-weight: 500; padding: 10px 18px; height: 40px;
    border-radius: var(--radius-md); text-decoration: none; transition: background 0.15s;
  }
  .btn-primary:hover { background: var(--color-primary-active); text-decoration: none; }
  .btn-secondary {
    display: inline-flex; align-items: center;
    background: transparent; color: var(--color-ink);
    font-size: 14px; font-weight: 500; padding: 9px 17px; height: 40px;
    border-radius: var(--radius-md); border: 1px solid var(--color-hairline-strong);
    text-decoration: none; transition: border-color 0.15s;
  }
  .btn-secondary:hover { border-color: var(--color-muted); text-decoration: none; }
  .hero-mockup-wrap {
    width: 100%;
    max-width: 880px;
    padding: 0 var(--space-xl);
    position: relative;
    z-index: 1;
  }
  .mockup-window {
    background: #0d0d0d;
    border-radius: 12px 12px 0 0;
    overflow: hidden;
    box-shadow: 0 -8px 40px rgba(0,0,0,0.12);
    border: 1px solid rgba(255,255,255,0.06);
    border-bottom: none;
  }
  .mockup-bar {
    background: #1a1a1a;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .mockup-dots { display: flex; gap: 6px; }
  .dot-r, .dot-y, .dot-g { width: 12px; height: 12px; border-radius: 50%; display: block; }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #ffbd2e; }
  .dot-g { background: #28c840; }
  .mockup-title {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #555;
    margin: 0 auto;
  }
  .mockup-body {
    padding: 20px 24px 32px;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 13px;
    line-height: 1.75;
  }
  .ml { display: block; color: #e0e0e0; }
  .mo { color: #777; padding-left: 16px; }
  .mt8 { margin-top: 8px; }
  .mp { color: #47c2ff; margin-right: 8px; }
  .mc { color: #e0e0e0; }
  .mc-cursor { color: #47c2ff; animation: blink 1s step-end infinite; }
  .mhi { color: #cfe7ff; }
  .mg { color: #28c840; }
  .mb { color: #47c2ff; }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  @media (max-width: 768px) {
    .hero h1 { font-size: 40px; letter-spacing: -1.2px; }
    .hero-stats { gap: var(--space-lg); }
    .stat-n { font-size: 22px; }
  }
  @media (max-width: 640px) {
    .hero-inner { padding: 64px var(--space-base) 48px; }
    .hero h1 { font-size: 32px; letter-spacing: -0.96px; }
    .hero-sub { font-size: 16px; }
    .stat-divider { display: none; }
    .hero-stats { gap: var(--space-xl); flex-wrap: wrap; }
    .hero-mockup-wrap { padding: 0; }
  }
</style>
