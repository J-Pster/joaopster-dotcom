---
import { useTranslations, defaultLang, type Lang } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const yearsBuilding = new Date().getFullYear() - 2020;
const numberWords: Record<Lang, string[]> = {
  pt: ['zero', 'um', 'dois', 'três', 'quatro', 'cinco', 'seis', 'sete', 'oito', 'nove', 'dez', 'onze', 'doze', 'treze', 'catorze', 'quinze', 'dezesseis', 'dezessete', 'dezoito', 'dezenove', 'vinte'],
  en: ['zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight', 'nine', 'ten', 'eleven', 'twelve', 'thirteen', 'fourteen', 'fifteen', 'sixteen', 'seventeen', 'eighteen', 'nineteen', 'twenty'],
  es: ['cero', 'uno', 'dos', 'tres', 'cuatro', 'cinco', 'seis', 'siete', 'ocho', 'nueve', 'diez', 'once', 'doce', 'trece', 'catorce', 'quince', 'dieciséis', 'diecisiete', 'dieciocho', 'diecinueve', 'veinte'],
};
const yearsWord = numberWords[lang][yearsBuilding] ?? String(yearsBuilding);
const expHeading1 = t('exp.heading1').replace('{years}', yearsWord);

const roles = [
  {
    roleKey: 'exp.role1.role' as const,
    company: 'Confidencial · PropTech',
    meta: 'United States · Remote',
    dates: '2025 - Present',
    current: true,
    descKey: 'exp.role1.desc' as const,
    tags: ['AI-driven', 'Spec-driven dev', 'TypeScript', 'Scale'],
  },
  {
    roleKey: 'exp.role2.role' as const,
    company: 'adMixt',
    meta: 'United States · Remote',
    dates: '2025',
    current: false,
    descKey: 'exp.role2.desc' as const,
    tags: ['Vanilla JS', 'Legacy modernization', 'PHP', 'AWS'],
  },
  {
    roleKey: 'exp.role3.role' as const,
    company: 'Howhow',
    meta: 'São Paulo · Hybrid',
    dates: '2024 - 2025',
    current: false,
    descKey: 'exp.role3.desc' as const,
    tags: ['AI / NLP', 'Architecture', 'Node.js', 'Full-stack'],
  },
  {
    roleKey: 'exp.role4.role' as const,
    company: 'Artweb · João Pster',
    meta: 'Brazil · Remote',
    dates: '2023 - 2025',
    current: false,
    descKey: 'exp.role4.desc' as const,
    tags: ['React', 'React Native', 'Angular', 'Flutter', 'GCP'],
  },
  {
    roleKey: 'exp.role5.role' as const,
    company: 'Independent',
    meta: 'Brazil · Remote',
    dates: '2021 - 2024',
    current: false,
    descKey: 'exp.role5.desc' as const,
    tags: ['React', 'Node', 'NestJS', 'Cloud'],
  },
  {
    roleKey: 'exp.role6.role' as const,
    company: 'João Pster',
    meta: 'Brazil · Remote',
    dates: '2023 - 2024',
    current: false,
    descKey: 'exp.role6.desc' as const,
    tags: ['Tech lead', 'Consulting', 'Hands-on', 'Team building'],
  },
  {
    roleKey: 'exp.role7.role' as const,
    company: 'Howhow · João Pster',
    meta: 'São Paulo · Hybrid',
    dates: '2023 - 2024',
    current: false,
    descKey: 'exp.role7.desc' as const,
    tags: ['CTO', 'AI / NLP', 'Leadership'],
  },
  {
    roleKey: 'exp.role8.role' as const,
    company: 'AfterSale',
    meta: 'Brazil · Remote',
    dates: '2023 - 2024',
    current: false,
    descKey: 'exp.role8.desc' as const,
    tags: ['React', 'Front-end', 'Legacy'],
  },
  {
    roleKey: 'exp.role9.role' as const,
    company: 'Digital Republic',
    meta: 'São Paulo · On-site',
    dates: '2023',
    current: false,
    descKey: 'exp.role9.desc' as const,
    tags: ['Next.js', 'Angular', 'Atomic Design'],
  },
  {
    roleKey: 'exp.role10.role' as const,
    company: 'Verzel',
    meta: 'Brazil · Remote',
    dates: '2022 - 2023',
    current: false,
    descKey: 'exp.role10.desc' as const,
    tags: ['Angular', 'React', 'Node', 'Chatbot'],
  },
  {
    roleKey: 'exp.role11.role' as const,
    company: 'Independent',
    meta: 'Brazil',
    dates: '2020 - 2022',
    current: false,
    descKey: 'exp.role11.desc' as const,
    tags: ['React', 'Angular', 'Vue', 'UI/UX'],
  },
  {
    roleKey: 'exp.role12.role' as const,
    company: 'Self-employed',
    meta: 'Remote',
    dates: '2019 - 2020',
    current: false,
    descKey: 'exp.role12.desc' as const,
    tags: ['.NET', 'C#', 'HarmonyX', 'Game dev'],
  },
];
---
<section id="experience" class="experience">
  <div class="exp-inner">
    <p class="exp-label">{t('exp.label')}</p>
    <h2 class="exp-heading">{expHeading1}<br/>{t('exp.heading2')}</h2>
    <p class="exp-sub">{t('exp.sub')}</p>

    <div class="exp-timeline">
      {roles.map((r, i) => (
        <div class:list={['exp-item', r.current && 'is-current', i >= 2 && 'exp-extra']}>
          <div class="exp-head">
            <h3 class="exp-role">{t(r.roleKey)}</h3>
            <span class="exp-dates">{r.dates}</span>
          </div>
          <p class="exp-company">
            <span class="exp-company-name">{r.company}</span>
            <span class="exp-company-meta">{r.meta}</span>
          </p>
          <div class="exp-desc">
            {t(r.descKey).split('\n\n').map((para) => (
              <p>{para.split('\n').map((line, li) => (<Fragment>{li > 0 && <br />}{line}</Fragment>))}</p>
            ))}
          </div>
          <div class="exp-tags">
            {r.tags.map(tag => <span class="exp-tag">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>

    {roles.length > 2 && (
      <div class="exp-more-wrap">
        <button type="button" class="exp-more-btn" aria-expanded="false" data-more={t('exp.showMore')} data-less={t('exp.showLess')}>
          {t('exp.showMore')}
        </button>
      </div>
    )}
  </div>
</section>

<script>
  const btn = document.querySelector('.exp-more-btn') as HTMLButtonElement | null;
  const timeline = document.querySelector('.exp-timeline');
  btn?.addEventListener('click', () => {
    const expanded = timeline?.classList.toggle('is-expanded') ?? false;
    btn.setAttribute('aria-expanded', String(expanded));
    btn.textContent = expanded ? btn.dataset.less ?? '' : btn.dataset.more ?? '';
  });
</script>

<style>
  .experience {
    background: var(--color-canvas);
    padding: var(--space-section) var(--space-xl);
    border-top: 1px solid var(--color-hairline);
  }
  .exp-inner { max-width: 760px; margin: 0 auto; }
  .exp-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.88px; text-transform: uppercase;
    color: var(--color-muted); margin-bottom: var(--space-md);
  }
  .exp-heading {
    font-size: 36px; font-weight: 600; color: var(--color-ink);
    letter-spacing: -1.08px; line-height: 1.15; margin: 0 0 var(--space-base);
  }
  .exp-sub { font-size: 16px; color: var(--color-body); line-height: 1.65; margin: 0 0 var(--space-xxl); }

  .exp-timeline {
    border-left: 1px solid var(--color-hairline-strong);
    padding-left: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }
  .exp-item { position: relative; }
  .exp-item::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-xl) - 5px);
    top: 5px;
    width: 9px; height: 9px;
    border-radius: 50%;
    background: var(--color-hairline-strong);
    border: 2px solid var(--color-canvas);
    box-shadow: 0 0 0 1px var(--color-hairline-strong);
  }
  .exp-item.is-current::before {
    background: #28c840;
    box-shadow: 0 0 0 1px #28c840, 0 0 0 5px rgba(40, 200, 64, 0.12);
  }

  .exp-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
    margin-bottom: 2px;
  }
  .exp-role { font-size: 17px; font-weight: 600; color: var(--color-ink); letter-spacing: -0.2px; line-height: 1.35; margin: 0; }
  .exp-dates {
    font-size: 12px; font-weight: 500; color: var(--color-muted);
    font-family: 'JetBrains Mono', monospace; white-space: nowrap; flex-shrink: 0;
  }
  .exp-company { display: flex; flex-wrap: wrap; align-items: baseline; gap: var(--space-xs) var(--space-sm); margin: 0 0 var(--space-sm); }
  .exp-company-name { font-size: 14px; font-weight: 600; color: var(--color-text-link); }
  .exp-company-meta { font-size: 13px; color: var(--color-muted); }
  .exp-desc { margin: 0 0 var(--space-md); }
  .exp-desc p { font-size: 14px; color: var(--color-body); line-height: 1.65; margin: 0 0 var(--space-sm); }
  .exp-desc p:last-child { margin-bottom: 0; }
  .exp-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .exp-tag {
    font-size: 11px; font-weight: 500; color: var(--color-ink);
    background: var(--color-surface-strong); border-radius: var(--radius-pill); padding: 3px 10px;
  }

  .exp-extra { display: none; }
  .exp-timeline.is-expanded .exp-extra { display: block; }
  .exp-more-wrap { display: flex; justify-content: center; margin-top: var(--space-xl); }
  .exp-more-btn {
    display: inline-flex; align-items: center; gap: var(--space-xs);
    background: var(--color-surface-card); color: var(--color-ink);
    font-size: 14px; font-weight: 500; font-family: inherit;
    padding: 9px 17px; height: 40px;
    border: 1px solid var(--color-hairline-strong); border-radius: var(--radius-md);
    cursor: pointer; transition: border-color 0.15s;
  }
  .exp-more-btn:hover { border-color: var(--color-muted); }

  .exp-note {
    margin: var(--space-xl) 0 0;
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-hairline);
    font-size: 14px; color: var(--color-muted); line-height: 1.6;
  }

  @media (max-width: 640px) {
    .experience { padding: var(--space-section) var(--space-base); }
    .exp-heading { font-size: 28px; }
    .exp-head { flex-direction: column; gap: 2px; }
    .exp-timeline { padding-left: var(--space-lg); }
    .exp-item::before { left: calc(-1 * var(--space-lg) - 5px); }
  }
</style>
