---
import { useTranslations, defaultLang, type Lang } from '../../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const prefix = lang === 'pt' ? '' : `/${lang}`;
---
<section class="stack-section">
  <div class="stack-inner">
    <div class="stack-text">
      <p class="section-label">{t('stack.label')}</p>
      <h2 class="section-heading">{t('stack.heading')}</h2>
      <p class="section-body">{t('stack.body')}</p>
      <ul class="stack-list">
        <li><span class="check">✓</span><span><strong>{t('stack.item1.name')}</strong>: {t('stack.item1.desc')}</span></li>
        <li><span class="check">✓</span><span><strong>{t('stack.item2.name')}</strong>: {t('stack.item2.desc')}</span></li>
        <li><span class="check">✓</span><span><strong>{t('stack.item3.name')}</strong>: {t('stack.item3.desc')}</span></li>
        <li><span class="check">✓</span><span><strong>{t('stack.item4.name')}</strong>: {t('stack.item4.desc')}</span></li>
      </ul>
      <a href={`${prefix}/blog`} class="stack-cta">{t('stack.cta')} →</a>
    </div>
    <div class="stack-code">
      <div class="code-window">
        <div class="code-header">
          <span class="code-lang">TypeScript</span>
          <span class="code-file">src/stack.ts</span>
        </div>
        <pre class="code-body"><code><span class="ck">import type</span> <span class="cv">&#123; NestApplication &#125;</span> <span class="ck">from</span> <span class="cs">'@nestjs/core'</span>
<span class="ck">import type</span> <span class="cv">&#123; ApplicationRef &#125;</span>  <span class="ck">from</span> <span class="cs">'@angular/core'</span>
<span class="ck">import type</span> <span class="cv">&#123; FC &#125;</span>              <span class="ck">from</span> <span class="cs">'react'</span>
<span class="ck">import type</span> <span class="cv">&#123; View &#125;</span>            <span class="ck">from</span> <span class="cs">'react-native'</span>

<span class="ck">type</span> <span class="cv">AIPhase</span> = <span class="cs">'spec'</span> | <span class="cs">'build'</span> | <span class="cs">'review'</span>

<span class="ck">interface</span> <span class="cv">SpecDriven</span> &#123;
  phase<span class="ck">:</span>    <span class="cv">AIPhase</span>
  reviewed<span class="ck">:</span> <span class="ck">true</span>
  vibe<span class="ck">:</span>     <span class="ck">never</span>
&#125;

<span class="ck">export interface</span> <span class="cv">Stack</span> &#123;
  server<span class="ck">:</span>  <span class="cv">NestApplication</span>
  web<span class="ck">:</span>     <span class="cv">ApplicationRef</span>
  spa<span class="ck">:</span>     <span class="cv">FC</span>
  mobile<span class="ck">:</span>  <span class="cv">View</span>
  ai<span class="ck">:</span>      <span class="cv">SpecDriven</span>
&#125;</code></pre>
      </div>
    </div>
  </div>
</section>

<style>
  .stack-section { padding: var(--space-section) var(--space-xl); background: var(--color-canvas); border-top: 1px solid var(--color-hairline); }
  .stack-inner { max-width: 1000px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-section); align-items: center; }
  /* Let the code column shrink so the <pre> scrolls internally instead of widening the page */
  .stack-text, .stack-code { min-width: 0; }
  .section-label { font-size: 11px; font-weight: 600; letter-spacing: 0.88px; text-transform: uppercase; color: var(--color-muted); margin-bottom: var(--space-md); }
  .section-heading { font-size: 36px; font-weight: 600; color: var(--color-ink); letter-spacing: -1.08px; line-height: 1.15; margin-bottom: var(--space-lg); white-space: pre-line; }
  .section-body { font-size: 15px; color: var(--color-body); line-height: 1.7; margin-bottom: var(--space-xl); }
  .stack-list { list-style: none; padding: 0; margin: 0 0 var(--space-xl); display: flex; flex-direction: column; gap: var(--space-sm); }
  .stack-list li { font-size: 14px; color: var(--color-body); line-height: 1.5; display: flex; gap: var(--space-sm); align-items: flex-start; }
  .stack-list li strong { color: var(--color-ink); font-weight: 600; }
  .check { color: var(--color-ink); font-weight: 600; flex-shrink: 0; }
  .stack-cta { font-size: 14px; font-weight: 500; color: var(--color-text-link); text-decoration: none; }
  .stack-cta:hover { text-decoration: underline; }
  .code-window { background: var(--color-surface-dark); border-radius: var(--radius-lg); overflow: hidden; border: 1px solid rgba(255,255,255,0.06); }
  .code-header { background: var(--color-surface-dark-elevated); padding: 10px 16px; display: flex; align-items: center; gap: var(--space-sm); border-bottom: 1px solid rgba(255,255,255,0.06); }
  .code-lang { font-size: 11px; font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; color: #47c2ff; }
  .code-file { font-size: 12px; color: #555; font-family: 'JetBrains Mono', monospace; margin-left: auto; }
  .code-body { margin: 0; padding: var(--space-lg) var(--space-xl); font-family: 'JetBrains Mono', monospace; font-size: 13px; line-height: 1.7; background: transparent; color: var(--color-on-dark); border-radius: 0; overflow-x: auto; }
  .code-body code { all: unset; font-family: inherit; font-size: inherit; }
  .ck { color: #c792ea; }
  .cv { color: #82aaff; }
  .cs { color: #c3e88d; }
  .cc { color: #546e7a; font-style: italic; }
  @media (max-width: 900px) { .stack-inner { grid-template-columns: 1fr; gap: var(--space-xxl); } }
  @media (max-width: 640px) { .stack-section { padding: var(--space-section) var(--space-base); } .section-heading { font-size: 28px; } .code-body { font-size: 12px; } }
</style>
