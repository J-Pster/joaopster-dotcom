---
import HeaderLink from './HeaderLink.astro';
import ContactModal from './ContactModal.astro';
import LanguageSelector from './LanguageSelector.astro';
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';

interface Props {
  codingTime?: string;
}

const { codingTime } = Astro.props;
const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const prefix = lang === 'pt' ? '' : `/${lang}`;
const homePath = lang === 'pt' ? '/' : `/${lang}`;
---

<header id="site-header">
  <nav>
    <a href={homePath} class="logo" aria-label="joaopster home">
      <svg class="logo-mark" viewBox="0 0 32 32" width="24" height="24" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="5" fill="#000000"/>
        <polyline points="10,9 22,16 10,23" stroke="#ffffff" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="logo-word">joaopster</span>
    </a>
    <div class="nav-center">
      <HeaderLink href={`${prefix}/blog`}>{t('nav.blog')}</HeaderLink>
      <a href={`${homePath}#about`} class="nav-text-link">{t('nav.about')}</a>
      <a href={`${homePath}#experience`} class="nav-text-link">{t('nav.experience')}</a>
      <a href={`${homePath}#build`} class="nav-text-link">{t('nav.more')}</a>
      {codingTime && (
        <a href={`${homePath}#opensource`} class="coding-time-pill" title="Total coded">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span class="pill-text-wrap">
            <span class="pill-time">{codingTime}</span>
            <span class="pill-label">total coded</span>
          </span>
        </a>
      )}
    </div>
    <div class="nav-end">
      {codingTime && (
        <a href={`${homePath}#opensource`} class="coding-time-pill coding-time-pill--mobile" title="Total coded">
          <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
          <span class="pill-text-wrap">
            <span class="pill-time">{codingTime}</span>
            <span class="pill-label">total coded</span>
          </span>
        </a>
      )}
      <a
        href="https://github.com/J-Pster"
        class="nav-icon-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path
            fill-rule="evenodd"
            d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z"
            clip-rule="evenodd"
          />
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/ojoaopster/"
        class="nav-icon-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a
        href="https://www.reddit.com/user/Joao-Pster/submitted/"
        class="nav-icon-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Reddit"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
        </svg>
      </a>
      <a
        href="https://wakatime.com/@JoaoPster"
        class="nav-icon-link"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WakaTime"
      >
        <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2c5.523 0 10 4.477 10 10S17.523 22 12 22 2 17.523 2 12 6.477 2 12 2zm0 2a8 8 0 1 0 0 16A8 8 0 0 0 12 4zm.75 3v5.25l4.5 2.25-.75 1.5-5.25-2.625V7h1.5z"/>
        </svg>
      </a>
      <a href="mailto:joaopster@proton.me" class="btn-nav" data-contact-open>{t('nav.getInTouch')}</a>
      <LanguageSelector />
      <button
        class="nav-hamburger"
        id="nav-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </button>
    </div>
  </nav>
</header>

<div class="nav-mobile" id="nav-mobile" aria-hidden="true">
  <nav class="nav-mobile-links" aria-label="Mobile">
      <a href={`${prefix}/blog`} class="nav-mobile-link">{t('nav.blog')}<span class="nav-mobile-arrow" aria-hidden="true">→</span></a>
      <a href={`${homePath}#about`} class="nav-mobile-link">{t('nav.about')}<span class="nav-mobile-arrow" aria-hidden="true">→</span></a>
      <a href={`${homePath}#experience`} class="nav-mobile-link">{t('nav.experience')}<span class="nav-mobile-arrow" aria-hidden="true">→</span></a>
      <a href={`${homePath}#build`} class="nav-mobile-link">{t('nav.more')}<span class="nav-mobile-arrow" aria-hidden="true">→</span></a>
    </nav>

    <div class="nav-mobile-footer">
      <a href="mailto:joaopster@proton.me" class="nav-mobile-cta" data-contact-open>{t('nav.getInTouch')}</a>

      <div class="nav-mobile-social">
        <a href="https://github.com/J-Pster" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg viewBox="0 0 20 20" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/ojoaopster/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a href="https://www.reddit.com/user/Joao-Pster/submitted/" target="_blank" rel="noopener noreferrer" aria-label="Reddit">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M12 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0zm5.01 4.744c.688 0 1.25.561 1.25 1.249a1.25 1.25 0 0 1-2.498.056l-2.597-.547-.8 3.747c1.824.07 3.48.632 4.674 1.488.308-.309.73-.491 1.207-.491.968 0 1.754.786 1.754 1.754 0 .716-.435 1.333-1.01 1.614a3.111 3.111 0 0 1 .042.52c0 2.694-3.13 4.87-7.004 4.87-3.874 0-7.004-2.176-7.004-4.87 0-.183.015-.366.043-.534A1.748 1.748 0 0 1 4.028 12c0-.968.786-1.754 1.754-1.754.463 0 .898.196 1.207.49 1.207-.883 2.878-1.43 4.744-1.487l.885-4.182a.342.342 0 0 1 .14-.197.35.35 0 0 1 .238-.042l2.906.617a1.214 1.214 0 0 1 1.108-.701zM9.25 12C8.561 12 8 12.562 8 13.25c0 .687.561 1.248 1.25 1.248.687 0 1.248-.561 1.248-1.249 0-.688-.561-1.249-1.249-1.249zm5.5 0c-.687 0-1.248.561-1.248 1.25 0 .687.561 1.248 1.249 1.248.688 0 1.249-.561 1.249-1.249 0-.687-.562-1.249-1.25-1.249zm-5.466 3.99a.327.327 0 0 0-.231.094.33.33 0 0 0 0 .463c.842.842 2.484.913 2.961.913.477 0 2.105-.056 2.961-.913a.361.361 0 0 0 .029-.463.33.33 0 0 0-.464 0c-.547.533-1.684.73-2.512.73-.828 0-1.979-.196-2.512-.73a.326.326 0 0 0-.232-.095z"/>
          </svg>
        </a>
        <a href="https://wakatime.com/@JoaoPster" target="_blank" rel="noopener noreferrer" aria-label="WakaTime">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm0 2c5.523 0 10 4.477 10 10S17.523 22 12 22 2 17.523 2 12 6.477 2 12 2zm0 2a8 8 0 1 0 0 16A8 8 0 0 0 12 4zm.75 3v5.25l4.5 2.25-.75 1.5-5.25-2.625V7h1.5z"/>
          </svg>
        </a>
      </div>

      <div class="nav-mobile-lang">
        <a href="/" class="lang-mobile-btn" data-lang-mobile="pt">🇧🇷 PT</a>
        <a href="/en" class="lang-mobile-btn" data-lang-mobile="en">🇺🇸 EN</a>
        <a href="/es" class="lang-mobile-btn" data-lang-mobile="es">🇪🇸 ES</a>
      </div>
    </div>
</div>

<ContactModal lang={lang} />

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.92);
    border-bottom: 1px solid var(--color-hairline);
    transition: box-shadow 0.2s ease, background 0.2s ease;
  }
  header.scrolled {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.04);
  }
  nav {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-xl);
    height: 64px;
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-ink);
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo:hover { text-decoration: none; color: var(--color-ink); }
  .logo-mark {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }
  .logo:hover .logo-mark { transform: translateY(-1px); }
  .logo-word {
    font-size: 15px;
    font-weight: 700;
    letter-spacing: -0.3px;
  }
  .nav-center {
    display: flex;
    align-items: center;
    gap: 2px;
    flex: 1;
  }
  .nav-text-link {
    display: inline-block;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-ink);
    text-decoration: none;
    padding: 6px var(--space-xs);
    border-radius: var(--radius-md);
    transition: color 0.15s ease;
  }
  .nav-text-link:hover { color: var(--color-text-link); text-decoration: none; }
  .coding-time-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 10px;
    background: var(--color-surface-strong);
    border-radius: var(--radius-pill);
    text-decoration: none;
    transition: background 0.15s;
    flex-shrink: 0;
    margin-left: var(--space-xs);
  }
  .coding-time-pill:hover { background: var(--color-hairline-strong); text-decoration: none; }
  .pill-text-wrap { display: flex; flex-direction: column; gap: 1px; }
  .pill-time { font-size: 12px; font-weight: 600; color: var(--color-ink); line-height: 1.2; }
  .pill-label { font-size: 10px; font-weight: 600; color: var(--color-muted); letter-spacing: 0.5px; text-transform: uppercase; line-height: 1; }
  .coding-time-pill--mobile { display: none; }
  .nav-end {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-shrink: 0;
  }
  .nav-icon-link {
    display: flex;
    align-items: center;
    color: var(--color-muted);
    transition: color 0.15s ease;
    padding: 4px;
  }
  .nav-icon-link:hover { color: var(--color-ink); text-decoration: none; }
  .btn-nav {
    display: inline-flex;
    align-items: center;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 14px;
    font-weight: 500;
    padding: 5px 14px;
    height: 30px;
    border-radius: var(--radius-md);
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.15s ease;
  }
  .btn-nav:hover { background: var(--color-primary-active); text-decoration: none; }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    padding: 8px;
    background: transparent;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: background 0.15s;
  }
  .nav-hamburger:hover { background: var(--color-surface-strong); }
  .bar {
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .nav-hamburger[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ── Full-screen mobile menu ─────────────────────────── */
  .nav-mobile {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 99;           /* full-screen overlay, just under the sticky header (z-index: 100) so the X stays tappable */
    flex-direction: column;
    background: var(--color-canvas);
    padding: calc(64px + var(--space-xl)) var(--space-lg) var(--space-xl);
    overflow-y: auto;
    overscroll-behavior: contain;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 0.24s ease, transform 0.24s ease, visibility 0.24s ease;
  }
  .nav-mobile-links {
    display: flex;
    flex-direction: column;
  }
  .nav-mobile-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.6px;
    color: var(--color-ink);
    text-decoration: none;
    padding: var(--space-base) 0;
    border-bottom: 1px solid var(--color-hairline);
    transition: color 0.15s;
  }
  .nav-mobile-link:hover,
  .nav-mobile-link:active { color: var(--color-text-link); text-decoration: none; }
  .nav-mobile-arrow {
    font-size: 18px;
    color: var(--color-muted-soft);
    transition: transform 0.15s ease, color 0.15s ease;
  }
  .nav-mobile-link:hover .nav-mobile-arrow {
    color: var(--color-text-link);
    transform: translateX(3px);
  }

  .nav-mobile-footer {
    margin-top: auto;
    padding-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-base);
  }
  .nav-mobile-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    font-size: 16px;
    font-weight: 500;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.15s ease;
  }
  .nav-mobile-cta:hover { background: var(--color-primary-active); text-decoration: none; }
  .nav-mobile-social {
    display: flex;
    gap: var(--space-sm);
  }
  .nav-mobile-social a {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 48px;
    background: var(--color-surface-strong);
    border-radius: var(--radius-md);
    color: var(--color-ink);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-mobile-social a:hover { background: var(--color-hairline-strong); text-decoration: none; }
  .nav-mobile-lang {
    display: flex;
    gap: var(--space-xs);
  }
  .lang-mobile-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    font-size: 13px;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-hairline-strong);
    transition: background 0.12s, color 0.12s;
  }
  .lang-mobile-btn:hover { background: var(--color-surface-strong); color: var(--color-ink); text-decoration: none; }

  @media (max-width: 768px) {
    .nav-center { display: none; }
    .nav-hamburger { display: flex; }
    .btn-nav { display: none; }
    .nav-icon-link { display: none; }
    nav { position: relative; z-index: 2; padding: 0 var(--space-base); gap: var(--space-md); }
    .nav-end { margin-left: auto; gap: var(--space-xs); }
    .coding-time-pill--mobile { display: inline-flex; }
    .nav-mobile { display: flex; }
    .nav-mobile.open {
      opacity: 1;
      visibility: visible;
      transform: none;
    }
  }

  @media (max-width: 640px) {
    nav { padding: 0 var(--space-base); }
  }

  @media (max-width: 400px) {
    .coding-time-pill--mobile .pill-label { display: none; }
  }
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const mobileNav = document.getElementById('nav-mobile');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 8);
  }, { passive: true });

  function setMenu(open: boolean) {
    mobileNav?.classList.toggle('open', open);
    toggle?.setAttribute('aria-expanded', String(open));
    mobileNav?.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  toggle?.addEventListener('click', () => {
    setMenu(!mobileNav?.classList.contains('open'));
  });

  // Close the menu on any link tap; the contact modal (z-index 200) opens above it
  mobileNav?.querySelectorAll<HTMLAnchorElement>('a').forEach(link => {
    link.addEventListener('click', () => setMenu(false));
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileNav?.classList.contains('open')) setMenu(false);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768 && mobileNav?.classList.contains('open')) setMenu(false);
  });

  // Mobile language switcher
  document.querySelectorAll<HTMLAnchorElement>('[data-lang-mobile]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const newLang = btn.dataset.langMobile ?? 'pt';
      const path = window.location.pathname;
      const nonDefault = ['en', 'es'];
      let stripped = path;
      for (const locale of nonDefault) {
        if (path.startsWith(`/${locale}/`)) {
          stripped = path.slice(locale.length + 1);
          break;
        } else if (path === `/${locale}`) {
          stripped = '/';
          break;
        }
      }
      window.location.href = newLang === 'pt' ? stripped : `/${newLang}${stripped}`;
    });
  });
</script>
