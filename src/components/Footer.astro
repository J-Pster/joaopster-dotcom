---
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const prefix = lang === 'pt' ? '' : `/${lang}`;
const homePath = lang === 'pt' ? '/' : `/${lang}`;
const today = new Date();
---

<footer>
  <div class="footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={homePath} class="footer-logo" aria-label="joaopster home">
          <span class="footer-mark" aria-hidden="true">›</span>
          <span class="footer-word">joaopster</span>
        </a>
        <p class="footer-tagline">{t('footer.tagline')}</p>
        <a
          href="https://github.com/J-Pster"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="social-link"
        >
          <svg viewBox="0 0 20 20" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
          </svg>
        </a>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">{t('footer.explore')}</h3>
        <ul class="footer-links">
          <li><a href={`${prefix}/blog`} class="footer-link">{t('nav.blog')}</a></li>
          <li><a href="/rss.xml" class="footer-link">{t('footer.rss')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">{t('footer.work')}</h3>
        <ul class="footer-links">
          <li><a href={`${homePath}#projects`} class="footer-link">{t('footer.projects')}</a></li>
          <li><a href="https://github.com/J-Pster" target="_blank" rel="noopener noreferrer" class="footer-link">{t('footer.allGithub')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h3 class="footer-col-heading">{t('footer.connect')}</h3>
        <ul class="footer-links">
          <li><a href="mailto:joaopster@proton.me" class="footer-link">{t('footer.email')}</a></li>
          <li><a href="https://www.linkedin.com/in/ojoaopster/" target="_blank" rel="noopener noreferrer" class="footer-link">LinkedIn</a></li>
          <li><a href="https://github.com/J-Pster" target="_blank" rel="noopener noreferrer" class="footer-link">GitHub</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">&copy; {today.getFullYear()} João Pster</p>
      <p class="footer-built">{t('footer.built')}</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--color-canvas-soft);
    border-top: 1px solid var(--color-hairline);
    width: 100%;
  }
  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 64px var(--space-xl) 40px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 2.2fr 1fr 1fr 1fr;
    gap: var(--space-xl);
    margin-bottom: var(--space-xxl);
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-base);
    max-width: 280px;
  }
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-ink);
    text-decoration: none;
  }
  .footer-logo:hover { text-decoration: none; color: var(--color-ink); }
  .footer-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: var(--color-primary);
    color: var(--color-on-primary);
    border-radius: var(--radius-sm);
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
    padding-bottom: 2px;
  }
  .footer-word { font-size: 15px; font-weight: 700; letter-spacing: -0.3px; }
  .footer-tagline { font-size: 14px; color: var(--color-body); line-height: 1.6; margin: 0; }
  .social-link { color: var(--color-muted); display: inline-flex; align-items: center; transition: color 0.15s ease; }
  .social-link:hover { color: var(--color-ink); text-decoration: none; }
  .footer-col { display: flex; flex-direction: column; gap: var(--space-sm); }
  .footer-col-heading {
    font-size: 11px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.88px; color: var(--color-muted); margin: 0 0 var(--space-xs);
  }
  .footer-links { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: var(--space-sm); }
  .footer-link { font-size: 14px; font-weight: 500; color: var(--color-body); text-decoration: none; transition: color 0.15s ease; line-height: 1.4; }
  .footer-link:hover { color: var(--color-ink); text-decoration: none; }
  .footer-bottom {
    border-top: 1px solid var(--color-hairline);
    padding-top: var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .footer-copyright, .footer-built { font-size: 13px; color: var(--color-muted); margin: 0; }
  @media (max-width: 768px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: var(--space-xl) var(--space-lg); }
    .footer-brand { grid-column: 1 / -1; max-width: none; }
  }
  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr 1fr; }
    .footer-inner { padding: 48px var(--space-base) 32px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; gap: var(--space-xs); }
  }
</style>
