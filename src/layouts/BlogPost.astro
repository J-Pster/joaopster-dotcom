---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingTime: number };

const { title, description, pubDate, updatedDate, readingTime } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <div class="reading-progress" id="reading-progress"></div>
    <Header />
    <main class="post-main">
      <div class="post-container">
        <nav class="post-breadcrumb">
          <a href="/blog" class="breadcrumb-link">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M8.5 2.5L4 7l4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back to blog
          </a>
        </nav>

        <header class="post-header">
          <div class="post-meta">
            <span class="post-date"><FormattedDate date={pubDate} /></span>
            <span class="post-readtime">{readingTime} min read</span>
            {updatedDate && (
              <span class="post-updated">Updated <FormattedDate date={updatedDate} /></span>
            )}
          </div>
          <h1 class="post-title">{title}</h1>
          {description && <p class="post-desc">{description}</p>}
        </header>

        <div class="prose">
          <slot />
        </div>

        <footer class="post-footer">
          <div class="post-footer-inner">
            <a href="/blog" class="back-link">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M8.5 2.5L4 7l4.5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              All posts
            </a>
            <a href="mailto:joaopster@proton.me" class="reply-link">Reply by email →</a>
          </div>
        </footer>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--color-ink);
    z-index: 200;
    transition: width 80ms linear;
  }
  .post-main {
    padding: var(--space-xxl) var(--space-base) var(--space-section);
  }
  .post-container {
    max-width: 680px;
    margin: 0 auto;
  }

  /* Breadcrumb */
  .post-breadcrumb {
    margin-bottom: var(--space-xl);
  }
  .breadcrumb-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .breadcrumb-link:hover { color: var(--color-ink); text-decoration: none; }

  /* Post header */
  .post-header {
    margin-bottom: var(--space-xxl);
    padding-bottom: var(--space-xxl);
    border-bottom: 1px solid var(--color-hairline);
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }
  .post-date {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    background: var(--color-surface-strong);
    padding: 3px 10px;
    border-radius: var(--radius-pill);
  }
  .post-updated {
    font-size: 12px;
    color: var(--color-muted);
    font-style: italic;
  }
  .post-readtime {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
  }
  .post-readtime::before {
    content: '·';
    margin-right: var(--space-md);
    color: var(--color-muted-soft);
  }
  .post-title {
    font-size: 36px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -1.08px;
    line-height: 1.15;
    margin: 0 0 var(--space-md);
  }
  .post-desc {
    font-size: 17px;
    color: var(--color-body);
    line-height: 1.65;
    margin: 0;
  }

  /* Prose */
  .prose {
    color: var(--color-body);
    font-size: 16px;
    line-height: 1.8;
  }
  .prose :global(p) { margin-bottom: 1.5em; }
  .prose :global(a) { color: var(--color-text-link); }
  .prose :global(a:hover) { text-decoration: underline; }
  .prose :global(h2) {
    font-size: 26px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.6px;
    margin: 2.5em 0 0.75em;
    line-height: 1.2;
  }
  .prose :global(h3) {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.3px;
    margin: 2em 0 0.5em;
    line-height: 1.3;
  }
  .prose :global(strong) { color: var(--color-ink); font-weight: 600; }
  .prose :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    background: var(--color-surface-strong);
    color: var(--color-ink);
    padding: 2px 6px;
    border-radius: var(--radius-xs);
  }
  .prose :global(pre) {
    background: var(--color-surface-dark);
    color: var(--color-on-dark);
    padding: var(--space-lg);
    border-radius: var(--radius-lg);
    overflow-x: auto;
    margin: 1.75em 0;
    border: 1px solid rgba(255,255,255,0.06);
  }
  .prose :global(pre code) {
    all: unset;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--color-on-dark);
    line-height: 1.7;
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--color-hairline-strong);
    padding-left: var(--space-lg);
    margin: 1.75em 0;
    color: var(--color-muted);
    font-style: italic;
  }
  .prose :global(ul), .prose :global(ol) {
    padding-left: var(--space-lg);
    margin-bottom: 1.5em;
  }
  .prose :global(li) { margin-bottom: 0.4em; }
  .prose :global(img) {
    border-radius: var(--radius-lg);
    max-width: 100%;
    border: 1px solid var(--color-hairline);
  }
  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-hairline);
    margin: 2.5em 0;
  }

  /* Post footer */
  .post-footer {
    margin-top: var(--space-xxl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-hairline);
  }
  .post-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-lg);
  }
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .back-link:hover { color: var(--color-ink); text-decoration: none; }
  .reply-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text-link);
    text-decoration: none;
  }
  .reply-link:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .post-main { padding: var(--space-lg) var(--space-base) var(--space-xxl); }
    .post-title { font-size: 28px; letter-spacing: -0.84px; }
    .post-desc { font-size: 15px; }
    .post-footer-inner { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  const bar = document.getElementById('reading-progress');
  const update = () => {
    const max = document.documentElement.scrollHeight - window.innerHeight;
    const pct = max > 0 ? (window.scrollY / max) * 100 : 0;
    if (bar) bar.style.width = `${Math.min(100, pct)}%`;
  };
  update();
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update, { passive: true });
</script>
