---
import { type CollectionEntry, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';
import { getPostsForLang } from '../../../lib/getLatestPost';

export async function getStaticPaths() {
  const posts = await getPostsForLang('en');
  return posts.map((post) => ({
    params: { slug: post.id.slice(post.id.indexOf('/') + 1) },
    props: post,
  }));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

const words = post.body?.trim().split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.round(words / 200));
---

<BlogPost {...post.data} readingTime={readingTime}>
  <Content />
</BlogPost>
