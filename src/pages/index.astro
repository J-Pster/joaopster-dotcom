---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import DarkAboutSection from '../components/sections/DarkAboutSection.astro';
import ExperienceSection from '../components/sections/ExperienceSection.astro';
import FeaturesGridSection from '../components/sections/FeaturesGridSection.astro';
import WorkflowSection from '../components/sections/WorkflowSection.astro';
import StackSection from '../components/sections/StackSection.astro';
import ProjectsSection from '../components/sections/ProjectsSection.astro';
import EcosystemSection from '../components/sections/EcosystemSection.astro';
import StatsBandSection from '../components/sections/StatsBandSection.astro';
import CTASection from '../components/sections/CTASection.astro';
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const prefix = lang === 'pt' ? '' : `/${lang}`;

// --- Wakatime (build-time fetch, API key never sent to browser) ---
interface WakatimeLanguage {
  name: string;
  percent: number;
  text: string;
}

interface WakatimeData {
  totalText: string;
  dailyAvgText: string;
  languages: WakatimeLanguage[];
}

function fmtSeconds(secs: number): string {
  const h = Math.floor(secs / 3600);
  const m = Math.floor((secs % 3600) / 60);
  return h > 0 ? `${h}h ${m}m` : `${m}m`;
}

const wakatimeApiKey = import.meta.env.WAKATIME_API_KEY as string | undefined;
let wakatimeData: WakatimeData | undefined;

if (wakatimeApiKey) {
  try {
    const auth = `Basic ${Buffer.from(wakatimeApiKey).toString('base64')}`;
    const headers = { Authorization: auth };
    const [allTimeRes, statsRes] = await Promise.all([
      fetch('https://wakatime.com/api/v1/users/current/all_time_since_today', { headers }),
      fetch('https://wakatime.com/api/v1/users/current/stats/last_30_days', { headers }),
    ]);
    if (allTimeRes.ok && statsRes.ok) {
      const allTime = (await allTimeRes.json()) as { data: { text: string; daily_average: number } };
      const statsJson = (await statsRes.json()) as { data: { languages: WakatimeLanguage[] } };
      wakatimeData = {
        totalText: allTime.data.text,
        dailyAvgText: fmtSeconds(allTime.data.daily_average),
        languages: (() => {
          const excluded = ['JSON', 'Markdown'];
          const allLangs = statsJson.data.languages;
          const excludedPct = allLangs
            .filter(l => excluded.includes(l.name))
            .reduce((sum, l) => sum + l.percent, 0);
          return allLangs
            .filter(l => !excluded.includes(l.name))
            .map(l => l.name === 'TypeScript' ? { ...l, percent: l.percent + excludedPct } : l)
            .slice(0, 4);
        })(),
      };
    }
  } catch {
    // build continues without data - card renders placeholders
  }
}
---
<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={t('site.title')} description={t('site.description')} />
  </head>
  <body>
    <Header codingTime={wakatimeData?.totalText} />
    <div class="page-sections">
      <HeroSection />
      <DarkAboutSection />
      <ExperienceSection />
      <FeaturesGridSection />
      <WorkflowSection
        variant="build"
        label={t('workflow.build.label')}
        heading={t('workflow.build.heading')}
        body={t('workflow.build.body')}
        cta={{ text: t('workflow.build.cta'), href: '#projects' }}
      />
      <WorkflowSection
        variant="write"
        label={t('workflow.write.label')}
        heading={t('workflow.write.heading')}
        body={t('workflow.write.body')}
        cta={{ text: t('workflow.write.cta'), href: `${prefix}/blog` }}
        flip={true}
      />
      <WorkflowSection
        variant="opensource"
        label={t('workflow.opensource.label')}
        heading={t('workflow.opensource.heading')}
        body={t('workflow.opensource.body')}
        addendum={t('workflow.opensource.addendum')}
        cta={{ text: t('workflow.opensource.cta'), href: 'https://wakatime.com/@JoaoPster' }}
        wakatimeData={wakatimeData}
      />
      <StackSection />
      <ProjectsSection />
      <EcosystemSection />
      <StatsBandSection />
      <CTASection />
    </div>
    <Footer />
  </body>
</html>

<style>
  .page-sections { width: 100%; }
</style>
