---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

const stack = ['TypeScript', 'React', 'Astro', 'Node.js', 'PostgreSQL', 'Tailwind', 'Vitest', 'Git', 'VS Code', 'Vercel'];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="About — joaopster"
      description="João Pster — developer, writer, and builder of things for the web."
    />
  </head>
  <body>
    <Header />

    <!-- Hero -->
    <section class="about-hero">
      <div class="about-hero-inner">
        <span class="badge">About me</span>
        <h1>Hey, I'm João.</h1>
        <p class="about-sub">
          Developer, occasional writer, and builder of things for the web. I lean towards
          TypeScript, developer tooling, and interfaces that don't get in the way.
        </p>
        <div class="about-ctas">
          <a href="https://github.com/joaopster" target="_blank" rel="noopener noreferrer" class="btn-primary">View GitHub</a>
          <a href="mailto:joaopster@proton.me" class="btn-secondary">Get in touch →</a>
        </div>
      </div>

      <div class="whoami-wrap">
        <div class="mockup-window">
          <div class="mockup-bar">
            <div class="mockup-dots"><span class="dot-r"></span><span class="dot-y"></span><span class="dot-g"></span></div>
            <span class="mockup-title">~/about — zsh</span>
          </div>
          <div class="mockup-body">
            <div class="ml"><span class="mp">❯</span> <span class="mc">whoami</span></div>
            <div class="ml mo">joaopster</div>
            <div class="ml mt8"><span class="mp">❯</span> <span class="mc">cat</span> <span class="ms">profile.json</span></div>
            <div class="ml mo"><span class="mpunc">&#123;</span></div>
            <div class="ml mo">  <span class="mk">"role"</span><span class="mpunc">:</span> <span class="ms">"Full-stack developer"</span><span class="mpunc">,</span></div>
            <div class="ml mo">  <span class="mk">"focus"</span><span class="mpunc">:</span> <span class="mpunc">[</span><span class="ms">"TypeScript"</span><span class="mpunc">,</span> <span class="ms">"DX"</span><span class="mpunc">,</span> <span class="ms">"tooling"</span><span class="mpunc">]</span><span class="mpunc">,</span></div>
            <div class="ml mo">  <span class="mk">"writes"</span><span class="mpunc">:</span> <span class="mbool">true</span><span class="mpunc">,</span></div>
            <div class="ml mo">  <span class="mk">"ships"</span><span class="mpunc">:</span> <span class="ms">"things that last"</span></div>
            <div class="ml mo"><span class="mpunc">&#125;</span></div>
            <div class="ml mt8"><span class="mp">❯</span> <span class="mc-cursor">█</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- What I do -->
    <section class="what-section">
      <div class="what-inner">
        <p class="section-label section-label--dark">What I do</p>
        <h2 class="section-heading section-heading--dark">Three things, done well.</h2>
        <div class="what-grid">
          <div class="what-card what-card--elevated">
            <div class="what-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M5 6l4 3-4 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10 12h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <h3>Building</h3>
            <p>Full-stack web development focused on developer experience and lasting quality. TypeScript-first, performance-minded, and allergic to unnecessary complexity.</p>
            <a href="/projects" class="what-link">See my projects →</a>
          </div>
          <div class="what-card what-card--elevated">
            <div class="what-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <path d="M3 5h12M3 9h8M3 13h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <h3>Writing</h3>
            <p>Technical articles, deep-dives, and opinions on tools and practices. I write when I find something worth sharing — which turns out to be fairly often.</p>
            <a href="/blog" class="what-link">Read the blog →</a>
          </div>
          <div class="what-card what-card--elevated">
            <div class="what-icon">
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                <circle cx="9" cy="9" r="7" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9 6v3l2 2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>Open Source</h3>
            <p>Tools I build for myself end up on GitHub. If they're useful to others, that's the best kind of bonus. Code is documentation.</p>
            <a href="https://github.com/joaopster" target="_blank" rel="noopener noreferrer" class="what-link">Browse on GitHub →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Currently -->
    <section class="currently-section">
      <div class="currently-inner">
        <p class="section-label">Currently</p>
        <h2 class="section-heading">What I'm working on.</h2>
        <div class="currently-list">
          <div class="currently-item">
            <div class="currently-dot currently-dot--active"></div>
            <div class="currently-text">
              <strong>This site</strong> — building a personal homepage inspired by expo.dev. Astro, TypeScript, zero JS by default.
            </div>
          </div>
          <div class="currently-item">
            <div class="currently-dot"></div>
            <div class="currently-text">
              <strong>Writing</strong> — documenting what I learn as I build, one post at a time.
            </div>
          </div>
          <div class="currently-item">
            <div class="currently-dot"></div>
            <div class="currently-text">
              <strong>Open source tools</strong> — small utilities that scratch real itches. Mostly TypeScript.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stack -->
    <section class="stack-about-section">
      <div class="stack-about-inner">
        <p class="section-label">Stack</p>
        <h2 class="section-heading">Tools I reach for.</h2>
        <div class="stack-pills">
          {stack.map(t => <span class="stack-pill">{t}</span>)}
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="contact-section">
      <div class="contact-inner">
        <h2>Want to talk?</h2>
        <p>I'm occasionally available for freelance projects and always happy to chat about ideas, tools, or what you're building.</p>
        <div class="contact-links">
          <a href="mailto:joaopster@proton.me" class="btn-primary-lg">Send an email</a>
          <a href="https://github.com/joaopster" target="_blank" rel="noopener noreferrer" class="btn-secondary-lg">GitHub profile</a>
        </div>
      </div>
    </section>

    <Footer />
  </body>
</html>

<style>
  /* Hero */
  .about-hero {
    background:
      radial-gradient(ellipse 110% 70% at 50% -15%, #cfe7ff 0%, #daeeff 20%, transparent 58%),
      var(--color-canvas);
    padding: 88px var(--space-xl) 80px;
    text-align: center;
    border-bottom: 1px solid var(--color-hairline);
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
  }
  .about-hero-inner { max-width: 640px; margin: 0 auto var(--space-xxl); }
  .badge {
    display: inline-block;
    font-size: 11px; font-weight: 600; letter-spacing: 0.88px; text-transform: uppercase;
    color: var(--color-muted); background: var(--color-surface-strong);
    padding: 4px 12px; border-radius: var(--radius-pill); margin-bottom: var(--space-lg);
  }
  .about-hero h1 {
    font-size: 48px; font-weight: 600; color: var(--color-ink);
    letter-spacing: -1.44px; line-height: 1.1; margin-bottom: var(--space-lg);
  }
  .about-sub { font-size: 17px; color: var(--color-body); line-height: 1.7; margin-bottom: var(--space-xl); }
  .about-ctas { display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap; }

  /* whoami terminal card */
  .whoami-wrap { width: 100%; max-width: 540px; }
  .mockup-window {
    background: #0d0d0d; border-radius: 12px; overflow: hidden;
    box-shadow: 0 12px 40px rgba(0,0,0,0.12); border: 1px solid rgba(255,255,255,0.06);
    text-align: left;
  }
  .mockup-bar {
    background: #1a1a1a; padding: 12px 16px; display: flex; align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .mockup-dots { display: flex; gap: 6px; }
  .dot-r, .dot-y, .dot-g { width: 12px; height: 12px; border-radius: 50%; display: block; }
  .dot-r { background: #ff5f57; } .dot-y { background: #ffbd2e; } .dot-g { background: #28c840; }
  .mockup-title { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #555; margin: 0 auto; }
  .mockup-body { padding: 20px 24px 28px; font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 13px; line-height: 1.8; }
  .ml { display: block; color: #e0e0e0; }
  .mo { color: #b0b4ba; padding-left: 16px; }
  .mt8 { margin-top: 8px; }
  .mp { color: #47c2ff; margin-right: 8px; }
  .mc { color: #e0e0e0; }
  .ms { color: #c3e88d; }
  .mk { color: #82aaff; }
  .mbool { color: #c792ea; }
  .mpunc { color: #777; }
  .mc-cursor { color: #47c2ff; animation: blink 1s step-end infinite; }
  @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

  /* Shared section styles */
  .section-label {
    font-size: 11px; font-weight: 600; letter-spacing: 0.88px; text-transform: uppercase;
    color: var(--color-muted); margin-bottom: var(--space-md);
  }
  .section-label--dark { color: var(--color-on-dark-soft); }
  .section-heading {
    font-size: 36px; font-weight: 600; color: var(--color-ink);
    letter-spacing: -1.08px; line-height: 1.15; margin-bottom: var(--space-xxl);
  }
  .section-heading--dark { color: var(--color-on-dark); }

  /* Buttons */
  .btn-primary {
    display: inline-flex; align-items: center;
    background: var(--color-primary); color: var(--color-on-primary);
    font-size: 14px; font-weight: 500; padding: 10px 18px; height: 40px;
    border-radius: var(--radius-md); text-decoration: none; transition: background 0.15s;
  }
  .btn-primary:hover { background: var(--color-primary-active); text-decoration: none; }
  .btn-secondary {
    display: inline-flex; align-items: center;
    background: transparent; color: var(--color-ink);
    font-size: 14px; font-weight: 500; padding: 9px 17px; height: 40px;
    border-radius: var(--radius-md); border: 1px solid var(--color-hairline-strong);
    text-decoration: none; transition: border-color 0.15s;
  }
  .btn-secondary:hover { border-color: var(--color-muted); text-decoration: none; }

  /* What I do */
  .what-section { background: var(--color-surface-dark); padding: var(--space-section) var(--space-xl); }
  .what-inner { max-width: 1000px; margin: 0 auto; }
  .what-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--space-base); }
  .what-card { border-radius: var(--radius-lg); padding: var(--space-lg); }
  .what-card--elevated { background: var(--color-surface-dark-elevated); border: 1px solid rgba(255,255,255,0.07); }
  .what-card h3 { color: var(--color-on-dark); font-size: 18px; font-weight: 600; margin: var(--space-md) 0 var(--space-sm); }
  .what-card p { color: var(--color-on-dark-soft); font-size: 14px; line-height: 1.65; margin-bottom: var(--space-lg); }
  .what-icon {
    width: 32px; height: 32px; background: rgba(255,255,255,0.08); border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center; color: var(--color-on-dark-soft);
  }
  .what-link { font-size: 13px; font-weight: 500; color: #47c2ff; text-decoration: none; }
  .what-link:hover { opacity: 0.8; text-decoration: none; }

  /* Currently */
  .currently-section { padding: var(--space-section) var(--space-xl); background: var(--color-canvas); border-top: 1px solid var(--color-hairline); }
  .currently-inner { max-width: 640px; margin: 0 auto; }
  .currently-list { display: flex; flex-direction: column; gap: var(--space-lg); }
  .currently-item { display: flex; gap: var(--space-lg); align-items: flex-start; }
  .currently-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--color-hairline-strong); flex-shrink: 0; margin-top: 5px; }
  .currently-dot--active { background: #28c840; box-shadow: 0 0 0 4px rgba(40,200,64,0.12); }
  .currently-text { font-size: 15px; color: var(--color-body); line-height: 1.6; }
  .currently-text strong { color: var(--color-ink); font-weight: 600; }

  /* Stack */
  .stack-about-section {
    padding: var(--space-section) var(--space-xl); background: var(--color-canvas-soft);
    border-top: 1px solid var(--color-hairline); border-bottom: 1px solid var(--color-hairline);
  }
  .stack-about-inner { max-width: 760px; margin: 0 auto; }
  .stack-pills { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
  .stack-pill {
    font-size: 13px; font-weight: 500; color: var(--color-ink);
    background: var(--color-surface-card); border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius-pill); padding: 5px 14px; transition: border-color 0.15s, transform 0.15s;
  }
  .stack-pill:hover { border-color: var(--color-muted); transform: translateY(-1px); }

  /* Contact */
  .contact-section { padding: var(--space-section) var(--space-xl); text-align: center; background: var(--color-canvas); border-top: 1px solid var(--color-hairline); }
  .contact-inner { max-width: 480px; margin: 0 auto; }
  .contact-section h2 { font-size: 36px; font-weight: 600; color: var(--color-ink); letter-spacing: -1.08px; margin-bottom: var(--space-md); }
  .contact-section p { font-size: 15px; color: var(--color-body); line-height: 1.65; margin-bottom: var(--space-xxl); }
  .contact-links { display: flex; gap: var(--space-sm); justify-content: center; flex-wrap: wrap; }
  .btn-primary-lg {
    display: inline-flex; align-items: center; background: var(--color-primary); color: var(--color-on-primary);
    font-size: 15px; font-weight: 500; padding: 12px 24px; height: 44px; border-radius: var(--radius-md);
    text-decoration: none; transition: background 0.15s;
  }
  .btn-primary-lg:hover { background: var(--color-primary-active); text-decoration: none; }
  .btn-secondary-lg {
    display: inline-flex; align-items: center; background: transparent; color: var(--color-ink);
    font-size: 15px; font-weight: 500; padding: 11px 23px; height: 44px; border-radius: var(--radius-md);
    border: 1px solid var(--color-hairline-strong); text-decoration: none; transition: border-color 0.15s;
  }
  .btn-secondary-lg:hover { border-color: var(--color-muted); text-decoration: none; }

  /* Responsive */
  @media (max-width: 900px) { .what-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) {
    .about-hero { padding: 64px var(--space-base) 56px; }
    .about-hero h1 { font-size: 36px; letter-spacing: -1.08px; }
    .about-sub { font-size: 15px; }
    .mockup-body { font-size: 12px; padding: 16px 18px 22px; }
    .what-section { padding: var(--space-section) var(--space-base); }
    .what-grid { grid-template-columns: 1fr; }
    .section-heading { font-size: 28px; }
    .currently-section, .stack-about-section, .contact-section { padding: var(--space-section) var(--space-base); }
  }
</style>
